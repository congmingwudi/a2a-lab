# ---- Anthropic (Claude agent) -------------------------------------------
ANTHROPIC_API_KEY=
# Claude hosting backend: managed (Anthropic Managed Agents beta, default)
# or sdk (self-hosted claude-agent-sdk)
CLAUDE_BACKEND=managed
# Managed Agents IDs — written by scripts/setup_managed_agent.py into
# .a2alab/managed.json; set here only to override.
#CLAUDE_MANAGED_AGENT_ID=
#CLAUDE_MANAGED_ENV_ID=
# Model for the research agent (Haiku-tier keeps Path A inside the
# Agentforce action timeout budget; A/B a Sonnet-tier later)
CLAUDE_AGENT_MODEL=claude-haiku-4-5
CLAUDE_ANSWER_TIMEOUT_S=40

# ---- Salesforce / Agentforce ---------------------------------------------
# My Domain host of the production org, e.g. mycompany.my.salesforce.com
SF_MY_DOMAIN=
# External Client App (client-credentials flow; scopes: api, chatbot_api,
# sfap_api, refresh_token) — see plan/04-runbooks.md
SF_CLIENT_ID=
SF_CLIENT_SECRET=
# 18-char Id of the published A2ALab service agent (Agent API requires a
# custom Service-type agent, published + active)
SF_AGENT_ID=

# ---- Bridge / tunnel ------------------------------------------------------
BRIDGE_TOKEN=
TUNNEL_HOSTNAME=bridge.lab.agenticthings.com

# ---- OpenAI (M9) ----------------------------------------------------------
OPENAI_API_KEY=

# ---- AWS / AgentCore (M8) -------------------------------------------------
AWS_PROFILE=
AWS_REGION=us-east-1

# ---- Lab internals --------------------------------------------------------
A2ALAB_TRACE_DIR=traces
