# ---- Anthropic (Claude agent) -------------------------------------------
ANTHROPIC_API_KEY=
# Claude hosting backend: managed (Anthropic Managed Agents beta, default)
# or sdk (self-hosted claude-agent-sdk)
CLAUDE_BACKEND=managed
# Managed Agents IDs — written by scripts/setup_managed_agent.py into
# .a2alab/managed.json; set here only to override.
#CLAUDE_MANAGED_AGENT_ID=
#CLAUDE_MANAGED_ENV_ID=
# Model for the research agent (Haiku-tier keeps Path A inside the
# Agentforce action timeout budget; A/B a Sonnet-tier later)
CLAUDE_AGENT_MODEL=claude-haiku-4-5
# Cap on one Claude answer. Needs headroom for Claude -> Agentforce (an
# Agent API round trip runs INSIDE Claude's turn, plus managed-session cold
# start). Agentforce -> Claude is governed by the tighter upstream chain
# regardless (bridge client 45s -> Apex 110s -> Agentforce action ~60s).
CLAUDE_ANSWER_TIMEOUT_S=100

# ---- Salesforce / Agentforce ---------------------------------------------
# My Domain host of the production org, e.g. mycompany.my.salesforce.com
SF_MY_DOMAIN=
# External Client App (client-credentials flow; scopes: api, chatbot_api,
# sfap_api, refresh_token) — see plan/04-runbooks.md
SF_CLIENT_ID=
SF_CLIENT_SECRET=
# 18-char Id of the published A2ALab service agent (Agent API requires a
# custom Service-type agent, published + active)
SF_AGENT_ID=

# ---- Bridge / tunnel ------------------------------------------------------
# Shared secret Salesforce sends the bridge (External Credential header).
BRIDGE_TOKEN=
# Shared secret for every OTHER tunnel-exposed app (claude-* protocol
# servers, shims, console /api/*). REQUIRED before running the tunnel —
# unset means those endpoints accept unauthenticated requests. Clients pick
# it up via config/targets.yaml; the console UI takes it as ?token=.
A2ALAB_TOKEN=
TUNNEL_HOSTNAME=bridge-lab.agenticthings.com

# ---- OpenAI (M9) ----------------------------------------------------------
OPENAI_API_KEY=

# ---- AWS / AgentCore (M8) -------------------------------------------------
AWS_PROFILE=
AWS_REGION=us-east-1

# ---- Lab internals --------------------------------------------------------
A2ALAB_TRACE_DIR=traces
# Trace sinks (ADR D13/D19/D23): jsonl | sqlite | dynamodb | postgres,
# comma-separated. Default jsonl,sqlite — JSONL is the raw archive,
# traces/lab.db is the console's query path (also holds the M11
# observability tables). postgres is the hosted Aurora store (D23);
# dynamodb is superseded but runnable (`uv sync --extra aws`, runbooks §6).
#A2ALAB_TRACE_SINK=jsonl,sqlite
#A2ALAB_TRACE_TABLE=a2alab-traces
#A2ALAB_TRACE_TTL_DAYS=14

# D23 hosted obs store (Aurora Postgres, runbooks §8). Data API pair (needs
# AWS creds; secret ARN picks the DB role — reader for console reads) OR a
# direct DSN. A2ALAB_OBS_STORE=postgres points obs_harvest at Aurora.
#A2ALAB_PG_CLUSTER_ARN=arn:aws:rds:us-east-1:...:cluster:a2alab-obs
#A2ALAB_PG_SECRET_ARN=arn:aws:secretsmanager:us-east-1:...:secret:a2alab/obs/reader-...
#A2ALAB_PG_DSN=postgres://lab_writer:...@a2alab-obs.cluster-....rds.amazonaws.com:5432/a2alab
#A2ALAB_OBS_STORE=sqlite
#A2ALAB_ANALYST_MODEL=claude-sonnet-5
# Details-tab component links (optional override)
#CLAUDE_AGENT_CONSOLE_URL=https://platform.claude.com/workspaces/default/agents
# Runbook 4 (action-timeout measurement): artificial delay in seconds the
# bridge adds before forwarding — leave unset/0 normally.
#A2ALAB_DELAY_S=0

# ---- Async account-brief pattern (D16) ------------------------------------
# Model for the long-running daily research agent (quality over latency —
# this path has no timeout budget to fit).
CLAUDE_BRIEF_MODEL=claude-sonnet-5
# Accounts the daily brief covers (comma/and-separated, passed verbatim)
A2ALAB_BRIEF_ACCOUNTS='Apple Inc.'
# Anthropic scheduled-deployment cron (fires on Anthropic's side)
A2ALAB_BRIEF_CRON=0 6 * * *
A2ALAB_BRIEF_TZ=America/Denver
# Cap on one research session (seconds)
A2ALAB_BRIEF_TIMEOUT_S=1800
# Who gets the in-app alert (defaults to active System Administrators)
#SF_ALERT_USERNAME=

# ---- OpenAI platform (M9/D24/D25) ----------------------------------------
# Backend for the OpenAI research agent: agents-sdk (real, needs
# OPENAI_API_KEY) or stub (deterministic, no network)
#OPENAI_BACKEND=agents-sdk
#OPENAI_API_KEY=
#OPENAI_MODEL=gpt-5-mini
#OPENAI_ANSWER_TIMEOUT_S=40
# OpenAI-paired Agentforce twin (ADR D25): the openai agent asks THIS
# agent; its external-research action targets openai-rest (never Claude)
#SF_OPENAI_AGENT_ID=

# ---- AWS AgentCore hosting (M8/M9/D26) ------------------------------------
# Runtime ARNs printed by deploy/agentcore/deploy.sh <platform>
#OPENAI_AGENTCORE_ARN=
#CLAUDE_AGENTCORE_ARN=
# Deployment mode (D26) — where Salesforce-originated delegations land.
# Only affects requests pinned to claude-rest / openai-rest (the Agentforce
# twins' actions, resolved via the bridge; see modes: in targets.yaml):
#   local  = bridge routes to the local servers (:8001 / :8011)
#   hosted = bridge remaps to the AgentCore runtimes (IAM/boto3, needs a
#            live `aws sso login`)
# Scenarios naming an agentcore target explicitly always hit AWS regardless;
# matrix.py cells always measure the exact target they name. Restart the
# stack after flipping — clients are cached per name.
#A2ALAB_MODE=local

# Runtimes write hops through the writer role (deploy.sh maps this over
# A2ALAB_PG_SECRET_ARN in container env; local keeps the reader)
#A2ALAB_PG_WRITER_SECRET_ARN=

# Delegation guard (D27): max onward-delegation depth a seam will forward
# (default 1 — a delegated-to agent answers itself). Riders + metadata
# carry the depth; see src/interop/delegation.py.
#A2ALAB_MAX_DELEGATION_DEPTH=1

# ---- GCP / ADK (WS2) -------------------------------------------------------
# Dedicated lab project (personal account; Agent Engine free tier covers
# lab volume — see plan/07-workstreams.md WS2)
#GOOGLE_CLOUD_PROJECT=
#GOOGLE_CLOUD_LOCATION=us-central1
#GOOGLE_GENAI_USE_VERTEXAI=TRUE
#ADK_MODEL=gemini-2.5-flash-lite
# Agent Engine deployment id + its native A2A endpoint (from the WS2 deploy)
#ADK_AGENT_ENGINE_ID=
#ADK_A2A_ENDPOINT=
# ADK-paired Agentforce twin (D25)
#SF_ADK_AGENT_ID=

# ---- Hosted Agentforce A2A shim (D28) --------------------------------------
# Written by deploy/shim/deploy_shim.sh — the a2a-shim channel endpoint the
# ask_agentforce_a2a tools call (API Gateway + Lambda; app auth x-lab-token)
#AF_SHIM_A2A_URL=
#AF_SHIM_TIMEOUT_S=34
