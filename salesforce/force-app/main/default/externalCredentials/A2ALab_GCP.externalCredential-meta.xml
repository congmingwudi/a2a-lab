<?xml version="1.0" encoding="UTF-8"?>
<!-- OAuth 2.0 JWT Bearer flow against Google's token endpoint: Salesforce
     signs the assertion with the A2ALab_GCP_JWT certificate (whose public
     key is registered on the GCP service account a2alab-sf-caller), and
     Google returns a cloud-platform access token — the direct
     Apex -> Vertex AI Agent Engine path, no bridge, no exported keys. -->
<ExternalCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>A2ALab GCP</label>
    <authenticationProtocol>Oauth</authenticationProtocol>
    <externalCredentialParameters>
        <parameterName>Oauth</parameterName>
        <parameterType>AuthProtocolVariant</parameterType>
        <parameterValue>JwtBearer</parameterValue>
    </externalCredentialParameters>
    <externalCredentialParameters>
        <parameterName>AuthProviderUrl</parameterName>
        <parameterType>AuthProviderUrl</parameterType>
        <parameterValue>https://oauth2.googleapis.com/token</parameterValue>
    </externalCredentialParameters>
    <externalCredentialParameters>
        <parameterName>iss</parameterName>
        <parameterType>JwtBodyClaim</parameterType>
        <parameterValue>a2alab-sf-caller@a2a-lab-d441.iam.gserviceaccount.com</parameterValue>
    </externalCredentialParameters>
    <externalCredentialParameters>
        <parameterName>aud</parameterName>
        <parameterType>JwtBodyClaim</parameterType>
        <parameterValue>"https://oauth2.googleapis.com/token"</parameterValue>
    </externalCredentialParameters>
    <externalCredentialParameters>
        <parameterName>scope</parameterName>
        <parameterType>JwtBodyClaim</parameterType>
        <parameterValue>https://www.googleapis.com/auth/cloud-platform</parameterValue>
    </externalCredentialParameters>
    <externalCredentialParameters>
        <parameterName>kid</parameterName>
        <parameterType>JwtHeaderClaim</parameterType>
        <parameterValue>508cbe24f1059808d6bebf015f613d534e749374</parameterValue>
    </externalCredentialParameters>
    <externalCredentialParameters>
        <certificate>A2ALab_GCP_JWT</certificate>
        <parameterName>SigningCertificate</parameterName>
        <parameterType>SigningCertificate</parameterType>
    </externalCredentialParameters>
    <externalCredentialParameters>
        <parameterName>A2ALab_GCP_Principal</parameterName>
        <parameterType>NamedPrincipal</parameterType>
        <sequenceNumber>1</sequenceNumber>
    </externalCredentialParameters>
</ExternalCredential>
