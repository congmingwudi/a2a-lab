<?xml version="1.0" encoding="UTF-8"?>
<!-- Direct Apex -> Vertex AI Agent Engine (no lab bridge): Google OAuth via
     the A2ALab_GCP external credential (JWT bearer, SF-held signing key).
     The callout URL is the regional aiplatform API host; the Apex client
     appends the engine's A2A path. The traced alternative stays the
     A2ALab_Bridge named credential - the operator picks per run. -->
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>false</allowMergeFieldsInHeader>
    <generateAuthorizationHeader>true</generateAuthorizationHeader>
    <label>A2ALab Agent Engine</label>
    <namedCredentialParameters>
        <parameterName>Url</parameterName>
        <parameterType>Url</parameterType>
        <parameterValue>https://us-central1-aiplatform.googleapis.com</parameterValue>
    </namedCredentialParameters>
    <namedCredentialParameters>
        <parameterName>ExternalCredential</parameterName>
        <parameterType>Authentication</parameterType>
        <externalCredential>A2ALab_GCP</externalCredential>
    </namedCredentialParameters>
    <namedCredentialType>SecuredEndpoint</namedCredentialType>
</NamedCredential>
