<?xml version="1.0" encoding="UTF-8"?>
<!-- Secured endpoint for the lab bridge. The URL points at the cloudflared
     tunnel hostname during local dev (M6) and is repointed to the AgentCore
     endpoint in M8. The X-Bridge-Token header carries the shared secret
     stored on the external credential principal. -->
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <calloutOptions>
        <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
        <allowMergeFieldsInHeader>true</allowMergeFieldsInHeader>
        <generateAuthorizationHeader>false</generateAuthorizationHeader>
    </calloutOptions>
    <label>A2ALab Bridge</label>
    <namedCredentialParameters>
        <parameterName>Url</parameterName>
        <parameterType>Url</parameterType>
        <parameterValue>https://bridge.lab.agenticthings.com</parameterValue>
    </namedCredentialParameters>
    <namedCredentialParameters>
        <parameterName>ExternalCredential</parameterName>
        <parameterType>Authentication</parameterType>
        <externalCredential>A2ALab_Bridge</externalCredential>
    </namedCredentialParameters>
    <namedCredentialParameters>
        <parameterName>X-Bridge-Token</parameterName>
        <parameterType>HttpHeader</parameterType>
        <parameterValue>{!$Credential.A2ALab_Bridge.BridgeToken}</parameterValue>
    </namedCredentialParameters>
    <namedCredentialType>SecuredEndpoint</namedCredentialType>
</NamedCredential>
