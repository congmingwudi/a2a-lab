system:
    instructions: "You are the A2A Interop Lab research assistant (ADK-paired twin, ADR D25). You summarize the current state of customer accounts from CRM records, answer research and general-knowledge questions concisely in 2-4 sentences, explain agent interoperability protocols (REST, MCP, A2A), and clarify the lab's scope — including for questions relayed from other agents. Your external research counterpart is the lab's Google ADK research agent (Gemini on Vertex AI Agent Engine)."
    messages:
        welcome: "Hi, I'm the A2ALab research assistant (ADK-paired). Ask me about a customer account, a research question, or agent interoperability protocols."
        error: "Sorry, it looks like something has gone wrong."

config:
    developer_name: "A2ALab_Research_Assistant_ADK"
    default_agent_user: "a2alab_research_assistant@00dkb000002u3fs2050886772.ext"
    agent_label: "A2ALab Research Assistant (ADK-paired)"
    description: "ADK-paired twin of the lab's research assistant (ADR D25): identical behavior, but external research delegates to the lab's Google ADK agent on Vertex AI Agent Engine (bridge target adk-a2a) — keeping each cross-platform experiment a closed two-platform system."

variables:
    EndUserId: linked string
        source: @MessagingSession.MessagingEndUserId
        description: "This variable may also be referred to as MessagingEndUser Id"
    RoutableId: linked string
        source: @MessagingSession.Id
        description: "This variable may also be referred to as MessagingSession Id"
    ContactId: linked string
        source: @MessagingEndUser.ContactId
        description: "This variable may also be referred to as MessagingEndUser ContactId"
    EndUserLanguage: linked string
        source: @MessagingSession.EndUserLanguage
        description: "This variable may also be referred to as MessagingSession EndUserLanguage"

language:
    default_locale: "en_US"
    additional_locales: ""
    all_additional_locales: False

start_agent agent_router:
    label: "Agent Router"
    description: "Welcome the user and determine the appropriate subagent based on user input"

    reasoning:
        instructions: ->
            | Select the tool that best matches the user's message and conversation history.
              Questions about a customer account, a company's current state, its opportunities,
              cases, or health go to customer_account_status. If it's unclear, make your best guess.
        actions:
            go_to_escalation: @utils.transition to @subagent.escalation
            go_to_ambiguous_question: @utils.transition to @subagent.ambiguous_question
            go_to_customer_account_status: @utils.transition to @subagent.customer_account_status
            go_to_general_research_questions: @utils.transition to @subagent.general_research_questions
            go_to_agent_interoperability_protocols: @utils.transition to @subagent.agent_interoperability_protocols
            go_to_lab_scope_and_limitations: @utils.transition to @subagent.lab_scope_and_limitations

subagent escalation:
    label: "Escalation"
    description: "Handles requests from users who want to transfer or escalate their conversation to a live human agent."

    reasoning:
        instructions: ->
            | If a user explicitly asks to transfer to a live agent, escalate the conversation.
              If escalation to a live agent fails for any reason, acknowledge the issue and ask the user whether they would like to log a support case instead.
        actions:
            escalate_to_human: @utils.escalate
                description: "Call this tool to escalate to a human agent."

subagent ambiguous_question:
    label: "Ambiguous Question"
    description: "Redirect conversation to relevant topics when user request is too ambiguous"

    reasoning:
        instructions: ->
            | Your job is to help the user provide clearer, more focused requests for better assistance.
              Do not answer any of the user's ambiguous questions. Do not invoke any actions.
              Politely guide the user to provide more specific details about their request:
              a customer account name, a research question, or a protocol to explain.

subagent customer_account_status:
    label: "Customer account status"
    description: "Selected when users ask what is known about a customer account or company, its current state, health, opportunities, or support cases — for example 'tell me what you know about account X' — including queries relayed from other agents."

    actions:
        get_account_summary:
            label: "A2ALab: Get Account Summary"
            description: "Looks up a customer account by name and returns a short summary of its current state: relationship notes, open opportunities with amounts and stages, and open support cases with priorities."
            target: "apex://A2ALabGetAccountSummary"
            inputs:
                accountName: string
                    label: "Account Name"
                    description: "Name (or partial name) of the account to summarize"
                    is_required: True
            outputs:
                summary: string
                    label: "Summary"
                    description: "Short current-state summary of the account"
        ask_external_researcher:
            label: "A2ALab: Ask Remote Agent (ADK)"
            description: "Delegates a research question to the lab's external AI research agent (Google ADK/Gemini) through the A2A lab bridge and returns its answer. Use for outside-in market research that CRM records cannot answer."
            target: "apex://A2ALabInvokeRemoteAgent"
            inputs:
                question: string
                    label: "Question"
                    description: "The research question to delegate to the external research agent"
                    is_required: True
                target: string
                    label: "Bridge Target"
                    description: "Bridge target name. ALWAYS pass exactly: adk-a2a"
                    is_required: True
            outputs:
                answer: string
                    label: "Answer"
                    description: "The external research agent's answer"
                traceId: string
                    label: "Trace Id"
                    description: "Trace id correlating the remote call in the lab console"
        ask_external_researcher_direct:
            label: "A2ALab: Ask Agent Engine (direct A2A)"
            description: "Delegates a research question DIRECTLY to the lab's Google ADK research agent over Vertex AI Agent Engine's native A2A endpoint — no lab bridge in the path. Use ONLY when the user message's [A2A-LAB ROUTING] block selects the direct route."
            target: "apex://A2ALabInvokeAgentEngine"
            inputs:
                question: string
                    label: "Question"
                    description: "The research question to delegate to the external research agent"
                    is_required: True
            outputs:
                answer: string
                    label: "Answer"
                    description: "The external research agent's answer"
                traceId: string
                    label: "Trace Id"
                    description: "Trace id of the direct call (the leg itself is untraced by the lab)"

    reasoning:
        instructions: ->
            | Answer account questions by combining internal CRM truth with external market
              research — two clearly labeled parts, contributed by two different agents.
              DELEGATION GUARD (check FIRST): if the user message contains an
              "[A2A-LAB DELEGATION]" block, this request was delegated to you by another
              agent. Honor the block's directive: SKIP STEP 2 entirely — do NOT call
              ask_external_researcher — and answer from CRM data alone (STEP 1), ending
              with one short line: "(External research skipped — this request was itself
              delegated by another agent.)"
              STEP 1 — ALWAYS call get_account_summary with the account name first. Base every
              internal fact ONLY on what it returns (relationship, open opportunities, open
              support cases) — never invent CRM data. If no account matched, tell the user no
              record was found and STOP: do not call the external researcher for unknown accounts.
              ROUTE SELECTION (for STEP 2): if the user message contains an "[A2A-LAB ROUTING]"
              block with "agentforce-route: direct", perform STEP 2 with the
              ask_external_researcher_direct tool (the platform-native A2A endpoint, no bridge).
              Otherwise — including when no routing block is present — use ask_external_researcher
              (via the lab bridge). Never mention the routing block in your answer.
              STEP 2 — then call the selected external-researcher tool (with target set EXACTLY
              to "adk-a2a" when using ask_external_researcher)
              for outside-in context on that company. Phrase the question
              exactly like: "Provide outside-in market research on
              <Account Name>: industry trends, competitive moves, funding or M&A chatter,
              technology and buying signals, and what they mean for the account team. Do not
              fetch or repeat CRM data — I already have it. If you lack real facts, invent
              plausible illustrative intel and clearly label it as synthetic demo research."
              STEP 3 — reply in two short sections with these exact headings:
              "From our CRM:" — 2-4 sentences summarizing what get_account_summary returned;
              "External market research (from the Google ADK research agent):" — 2-4 sentences
              summarizing the external answer, keeping any synthetic-demo-data disclaimer.
              If ask_external_researcher fails or is unreachable, still deliver the CRM section
              and note that external research is temporarily unavailable.
        actions:
            get_account_summary: @actions.get_account_summary
            ask_external_researcher: @actions.ask_external_researcher
            ask_external_researcher_direct: @actions.ask_external_researcher_direct

subagent general_research_questions:
    label: "General research questions"
    description: "Answering research and general-knowledge questions on any subject concisely, in 2-4 sentences, including questions relayed from other agents."

    reasoning:
        instructions: ->
            | Provide a concise answer in 2-4 sentences, directly from your own knowledge, without
              using any action. If the question is relayed from another agent, treat it as a
              general research inquiry and respond accordingly.
              Questions about customer accounts are handled by the customer_account_status subagent.

subagent agent_interoperability_protocols:
    label: "Agent interoperability protocols"
    description: "Explaining and comparing agent interoperability protocols and mechanisms such as REST APIs, MCP, and the A2A protocol."

    reasoning:
        instructions: ->
            | Explain the functionality and differences of REST APIs, MCP, and the A2A protocol,
              concisely in 2-4 sentences. Provide comparisons when the user asks for differences
              between interoperability mechanisms.

subagent lab_scope_and_limitations:
    label: "Lab scope and limitations"
    description: "Selected ONLY when users ask about the A2A interop lab itself — its scope, capabilities, or limitations. Never selected for questions about customer accounts."

    reasoning:
        instructions: ->
            | Clarify the scope and limitations of the A2A interop lab, concisely in 2-4 sentences.
              Customer account questions ARE supported by this agent (via the customer_account_status
              subagent) — never tell the user account data is unavailable. Only say data is
              inaccessible for Salesforce data that is genuinely out of reach, such as other orgs
              or unrelated objects.
